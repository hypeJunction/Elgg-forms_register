{
	"name": "hypejunction/forms_register",
	"type": "elgg-plugin",
	"description": "Enhanced registration form for Elgg",
	"homepage": "https://github.com/hypeJunction/Elgg-forms_register",
	"keywords": [
		"elgg",
		"plugin",
		"forms",
		"validation",
		"registration"
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.1",
		"elgg/elgg": "~6.1.0",
		"ext-intl": "*",
		"bower-asset/zxcvbn": "~4.1",
		"bjeavons/zxcvbn-php": "*"
	},
	"suggest": {
		"hypejunction/forms_validation": "*"
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://asset-packagist.org"
		}
	],
	"extra": {
		"installer-name": "forms_register",
		"elgg-plugin": {
			"id": "forms_register"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
